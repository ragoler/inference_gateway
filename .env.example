# Google Cloud Project ID
PROJECT_ID=your-gcp-project-id

# Backend hardware. The demo is GPU-only (the load-test comparison); shown in the
# UI badge. Leave as gpu.
BACKEND=gpu

# Name of the GKE cluster + gateway. Use a DISTINCT name per cluster so you never
# touch an existing one.
CLUSTER_NAME=gpu-flex-cluster
GATEWAY_NAME=inference-gw-gpu

# Google Cloud region / zone.
REGION=us-west1
ZONE=us-west1-a

# Small on-demand DEFAULT pool (hosts gateway/EPP/app only; the vLLM model servers
# run on the gpu-flex Custom Compute Class and SHARE one GPU).
MACHINE_TYPE=e2-standard-8
NUM_NODES=2

# --- GPU sharing: run REPLICAS vLLM pods on ONE physical GPU ---------------
# Requires GKE >= 1.35.2-gke.1485000 (ComputeClass GPU sharing). GPU_MAX_SHARED
# must be >= REPLICAS; the per-pod memory fractions must sum to < ~0.9.
REPLICAS=4
GPU_MEM_UTIL=0.20
GPU_SHARING_STRATEGY=TIME_SHARING   # or MPS (MPS also needs hostIPC:true on the pod)
GPU_MAX_SHARED=4
BLOCK_SIZE=16                        # must match vLLM --block-size <-> EPP blockSize

# GPU Node Auto-Provisioning limits. Both types the gpu-flex ComputeClass can pick:
# G4 = nvidia-rtx-pro-6000 (preferred), G2 = nvidia-l4 (fallback).
GPU_ACCELERATOR_TYPE=nvidia-rtx-pro-6000
GPU_ACCELERATOR_TYPE_FALLBACK=nvidia-l4
MAX_GPU=8

# Gateway class. Internal (gke-l7-rilb) keeps the llm-d path in-cluster so it is
# apples-to-apples with the in-cluster round-robin baseline. Use
# gke-l7-regional-external-managed if you want a public IP.
GATEWAY_CLASS=gke-l7-rilb

# HuggingFace Model ID for vLLM (configurable; start small).
MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct

# CPU KV cache space (GB). Ignored on GPU (uses --gpu-memory-utilization); harmless.
KV_CACHE_SPACE=4

# FastAPI Application Port
APP_PORT=8000

# Optional: app image tag. Defaults to CLUSTER_NAME so clusters never share a tag.
# IMAGE_TAG=gpu-flex-cluster
