# Google Cloud Project ID
PROJECT_ID=your-gcp-project-id

# Backend hardware for THIS cluster: cpu | gpu (one backend per cluster).
# Selects the model-server manifest, the Custom Compute Class, and BLOCK_SIZE.
BACKEND=cpu

# Optional: override the KV block size (must match vLLM <-> EPP). Defaults by
# backend if unset: cpu=128, gpu=16.
# BLOCK_SIZE=128

# Optional GPU Node Auto-Provisioning limits (only used when BACKEND=gpu):
# GPU_ACCELERATOR_TYPE=nvidia-l4
# MAX_GPU=8

# Name of the GKE cluster. Use a DISTINCT name per backend so you never touch an
# existing cluster, e.g. cpu-flex-cluster (BACKEND=cpu) / gpu-flex-cluster (BACKEND=gpu).
CLUSTER_NAME=cpu-flex-cluster

# Google Cloud Zone
ZONE=us-east5-a

# Node machine type for CPU inference
MACHINE_TYPE=e2-standard-16

# Initial number of nodes
NUM_NODES=3

# Name of the Gateway resource
GATEWAY_NAME=inference-gateway

# HuggingFace Model ID for vLLM
MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct

# CPU KV Cache Space in GB
KV_CACHE_SPACE=4

# FastAPI Application Port
APP_PORT=8000
